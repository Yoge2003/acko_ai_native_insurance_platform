# ─────────────────────────────────────────────────────────────────────────────
# ACKO AI Native Insurance Platform — Environment Variables Template
# Copy this file to .env and fill in all values before running the application.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL 17 Database ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=acko_insurance_db
POSTGRES_USER=acko_user
POSTGRES_PASSWORD=your_strong_password_here

# ── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ChromaDB Vector Store ─────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── AWS S3 Object Storage (for document / image uploads) ──────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=acko-insurance-assets

# ── Application Security ──────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_minimum_32_characters_here

# ── Application Runtime Settings ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
